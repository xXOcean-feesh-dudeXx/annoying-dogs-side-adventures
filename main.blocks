pe="game_show_long_text" id="#vBg%AEnY`#}aQl`hjF)"><field name="layout">DialogLayout.Top</field><value name="str"><shadow type="text" id=",L.nP*=i$eb6bYjQu]:["><field name="TEXT">* Felis put up quite a fight.</field></shadow></value><next><block type="game_show_long_text" id="^:idW6wH%gM7q53n{{YO"><field name="layout">DialogLayout.Top</field><value name="str"><shadow type="text" id="xPA-6bo*H/ZKFmR2C0V-"><field name="TEXT">* Asgore, what if...</field></shadow></value><next><block type="game_show_long_text" id="bTNnryIv4x*S8sc-:VSS"><field name="layout">DialogLayout.Top</field><value name="str"><shadow type="text" id="w0nNl!aA$:bT`/HH])h5"><field name="TEXT">* There is a human we can't defeat?</field></shadow></value><next><block type="game_show_long_text" id="?ufAf;wOsQjr3g]jW!u2"><field name="layout">DialogLayout.Top</field><value name="str"><shadow type="text" id="@Pr~ux6/}pOa-C[f8Bvg"><field name="TEXT">* Do not worry, Undyne. We have power beyond any human even now.</field></shadow></value><next><block type="game_show_long_text" id="CQWQx.U#c1LZ.~De:9-7"><field name="layout">DialogLayout.Top</field><value name="str"><shadow type="text" id="qKMO[4VaMe`u[!,iGc75"><field name="TEXT">* The chance of defeat is so slim, you could fold it eight times and it could fit through a pinhole still!</field></shadow></value><next><block type="game_show_long_text" id="MAfj|;klO9/,+u46h7=P"><field name="layout">DialogLayout.Top</field><value name="str"><shadow type="text" id="Tzp^v-^:09zaFv9fNBC("><field name="TEXT">* Yeah! With your training, I am getting stronger everyday, more DETERMINED.</field></shadow></value><next><block type="game_show_long_text" id="I.gV]~$;seLi.NoUx`_w"><field name="layout">DialogLayout.Top</field><value name="str"><shadow type="text" id="]A5fmIbI]s0aD#F$;a{X"><field name="TEXT">* No human shall defeat us monsters!</field></shadow></value><next><block type="spritedestroy2" id="Y.g=)3Ux(+*,c~]3oPVc"><mutation xmlns="http://www.w3.org/1999/xhtml" _expande